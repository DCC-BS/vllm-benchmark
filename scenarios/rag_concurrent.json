{
    "spec": {
        "profile": {
            "kind": "concurrent",
            "streams": [10, 50, 100, 300],
            "warmup": { "percent": 0.1 },
            "cooldown": { "percent": 0.05 }
        },
        "data": [
            {
                "kind": "synthetic_text",
                "prompt_tokens": 4096,
                "prompt_tokens_stdev": 512,
                "prompt_tokens_min": 2048,
                "prompt_tokens_max": 16000,
                "output_tokens": 512,
                "output_tokens_stdev": 128,
                "output_tokens_min": 1,
                "output_tokens_max": 2048
            }
        ],
        "constraints": [
            { "kind": "max_requests", "count": 1000 },
            { "kind": "max_duration", "seconds": 600 }
        ]
    }
}
