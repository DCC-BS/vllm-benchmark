# Target OpenAI-compatible endpoint (base URL, no /v1 suffix).
BENCH_TARGET="https://your-gemma-endpoint.example.com"

# Model id as served by the endpoint. Leave empty to auto-detect via /v1/models.
BENCH_MODEL=""

# Hugging Face repo id used for tokenization. Defaults to BENCH_MODEL when empty.
# Set explicitly if the server reports a deployment alias rather than a repo id.
BENCH_TOKENIZER=""

# Bearer-token auth. guidellm sends this as "Authorization: Bearer <value>".
BENCH_API_KEY=""

# Raw Authorization header value (sent verbatim, no "Bearer " prefix).
# Takes precedence over BENCH_API_KEY.
BENCH_AUTH_HEADER=""

# Verify the server TLS certificate.
BENCH_VERIFY="false"

# Needed for gated tokenizers (e.g. google/gemma-*).
HF_TOKEN=""
