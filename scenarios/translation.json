{
    "spec": {
        "profile": {
            "kind": "sweep",
            "sweep_size": 10,
            "warmup": { "percent": 0.1 },
            "cooldown": { "percent": 0.05 }
        },
        "data": [
            {
                "kind": "synthetic_text",
                "prompt_tokens": 1024,
                "prompt_tokens_stdev": 256,
                "prompt_tokens_min": 1,
                "prompt_tokens_max": 2048,
                "output_tokens": 1024,
                "output_tokens_stdev": 256,
                "output_tokens_min": 1,
                "output_tokens_max": 2048
            }
        ],
        "constraints": [
            { "kind": "max_requests", "count": 1000 },
            { "kind": "max_duration", "seconds": 600 },
            { "kind": "over_saturation", "mode": "monitor" }
        ]
    }
}
